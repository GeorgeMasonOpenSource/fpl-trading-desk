# --- Database (Neon Free or Neon Launch) -----------------------------------
# Pooled URL is used by API routes (serverless). Direct URL is used by migrations / GH Actions.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# --- Application -----------------------------------------------------------
NEXT_PUBLIC_APP_NAME="FPL Trading Desk"
# Active manager being tracked (your own FPL Team ID, integer, e.g. 1234567)
FPL_MANAGER_ID=
# Mini league you want to monitor (Classic league ID, integer)
FPL_LEAGUE_ID=

# --- Ingest job auth ------------------------------------------------------
# Random secret used to authenticate GitHub Actions hitting /api/ingest/*
INGEST_SECRET=replace-me-with-a-long-random-string

# --- Modelling toggles ----------------------------------------------------
# Allow expensive optimisation paths to run from the UI. Default off for cost control.
ALLOW_USER_OPTIMISATION=true
# Expected-value threshold (in points) below which the engine recommends rolling/no-op
EV_TRANSFER_THRESHOLD=0.6
# Hit threshold: a -4 must clear this many net points to be recommended
EV_HIT_THRESHOLD=1.5
